# Supabase (client + SSR)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Vercel AI Gateway (scorecard LLM features + Eve agent)
# Use AI_GATEWAY_API_KEY locally, or run `vercel env pull` for VERCEL_OIDC_TOKEN
AI_GATEWAY_API_KEY=
# AI_SCORECARD_MODEL=google/gemini-2.5-flash

# Eve local development (optional — defaults to http://127.0.0.1:4274)
# EVE_BASE_URL=http://127.0.0.1:4274
