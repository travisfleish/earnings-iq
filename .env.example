# Supabase (client + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Vercel AI Gateway (scorecard LLM features + Eve agent)
# Prefer AI_GATEWAY_API_KEY — bills against purchased AI Gateway credits.
# VERCEL_OIDC_TOKEN (from `vercel env pull`) uses the free monthly pool even on Vercel Pro.
# VERCEL_AI_API_KEY is also accepted as an alias for AI_GATEWAY_API_KEY.
AI_GATEWAY_API_KEY=
# VERCEL_AI_API_KEY=
# AI_SCORECARD_MODEL=google/gemini-2.5-flash
# AI_ANALYSIS_MODEL=perplexity/sonar

# ElevenLabs (report → podcast audio briefs)
ELEVENLABS_API_KEY=
